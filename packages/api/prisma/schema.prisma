generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), postgis, pgcrypto, pgStatStatements(map: "pg_stat_statements")]
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId   String    @unique @map("clerk_id")
  email     String    @unique
  name      String?
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  profile      UserProfile?
  priceReports PriceReport[]
  savedGyms    SavedGym[]
  trips        Trip[]
  gymAccess    GymAccess[]

  chatThreads  ChatThread[]
  @@map("users")
  bookingInterests BookingInterest[]
}

model UserProfile {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  primaryActivity    String   @default("staying_in_shape") @map("primary_activity")
  activities         String[] @default([])
  facilityTypes      String[] @default([]) @map("facility_types")
  lifestyle          String[] @default([])
  priorities         String[] @default([])
  monthlyBudget      String   @default("any_quality") @map("monthly_budget")
  travelDailyBudget  String   @default("any_quality") @map("travel_daily_budget")
  maxDistanceMinutes Int      @default(20) @map("max_distance_minutes")
  trainingPattern    String?  @map("training_pattern")
  themePreference    String   @default("dark") @map("theme_preference")
  onboarded          Boolean  @default(false)
  citySlug           String?  @map("city_slug")
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Gym {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  placesId      String   @unique @map("places_id")
  name          String
  address       String
  lat           Float
  lng           Float
  openingHours  Json?    @map("opening_hours")
  equipmentTags String[] @default([]) @map("equipment_tags")
  photoUrls     String[]      @default([]) @map("photo_urls")
  websiteUrl    String?   @map("website_url")
  citySlug      String?   @map("city_slug")
  dayPass       Boolean   @default(false) @map("day_pass")
  dayPassPence  Int?      @map("day_pass_pence")
  dayPassUrl    String?   @map("day_pass_url")
  verified      Boolean   @default(false)
  verifiedAt    DateTime? @map("verified_at") @db.Timestamptz
  rating        Float?
  ratingCount   Int?     @map("rating_count")
  lastFetchedAt DateTime @default(now()) @map("last_fetched_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  priceReports PriceReport[]
  savedBy      SavedGym[]
  tripGyms     TripGym[]
  gymAccess    GymAccess[]

  @@map("gyms")
  bookingInterests BookingInterest[]
}

model PriceReport {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gymId        String   @map("gym_id") @db.Uuid
  reportedBy   String   @map("reported_by") @db.Uuid
  dayPassPence Int?     @map("day_pass_pence")
  weeklyPence  Int?     @map("weekly_pence")
  monthlyPence Int?     @map("monthly_pence")
  verified     Boolean  @default(false)
  visitedAt    DateTime @map("visited_at") @db.Date
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  gym          Gym  @relation(fields: [gymId], references: [id])
  reportedByUser User @relation(fields: [reportedBy], references: [id])

  @@map("price_reports")
}

model SavedGym {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  gymId   String   @map("gym_id") @db.Uuid
  savedAt DateTime @default(now()) @map("saved_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])
  gym  Gym  @relation(fields: [gymId], references: [id])

  @@unique([userId, gymId])
  @@map("saved_gyms")
}

model GymAccess {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  gymId          String    @map("gym_id") @db.Uuid
  citySlug       String    @map("city_slug")
  accessType     String    @map("access_type")
  pricePaidPence Int?      @map("price_paid_pence")
  activatedAt    DateTime  @default(now()) @map("activated_at") @db.Timestamptz
  expectedEndDate DateTime @map("expected_end_date") @db.Date
  reminderSentAt DateTime? @map("reminder_sent_at") @db.Timestamptz
  cancelledAt    DateTime? @map("cancelled_at") @db.Timestamptz
  status         String    @default("pending")
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])
  gym  Gym  @relation(fields: [gymId], references: [id])

  @@index([userId])
  @@index([expectedEndDate])
  @@map("gym_access")
}

model Route {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citySlug       String   @map("city_slug")
  name           String
  description    String?
  distanceKm     Float    @map("distance_km")
  terrainType    String   @map("terrain_type")
  surfaceType    String   @map("surface_type")
  safetyRating   String   @map("safety_rating")
  elevationGainM Int      @default(0) @map("elevation_gain_m")
  gpxUrl         String?  @map("gpx_url")
  source         String
  sourceId       String?  @map("source_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  tripRoutes TripRoute[]

  @@map("routes")
}

model Park {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  osmId         String    @unique @map("osm_id")
  name          String?
  lat           Float
  lng           Float
  equipmentTags String[]  @default([]) @map("equipment_tags")
  isFree        Boolean   @default(true) @map("is_free")
  surface       String?
  lastVerifiedAt DateTime? @map("last_verified_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("parks")
}

model CommunityGroup {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citySlug          String    @map("city_slug")
  name              String
  type              String
  meetupId          String?   @map("meetup_id")
  externalUrl       String?   @map("external_url")
  visitorsWelcome   Boolean   @default(false) @map("visitors_welcome")
  nextEventAt       DateTime? @map("next_event_at") @db.Timestamptz
  nextEventLocation String?   @map("next_event_location")
  memberCount       Int?      @map("member_count")
  cacheExpiresAt    DateTime  @map("cache_expires_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("community_groups")
}

model Trip {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user       User        @relation(fields: [userId], references: [id])
  legs       TripLeg[]
  tripGyms   TripGym[]
  tripRoutes TripRoute[]

  @@index([userId])
  @@map("trips")
  bookingInterests BookingInterest[]
}

model TripLeg {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  city      String
  citySlug  String   @map("city_slug")
  country   String?
  placeId          String?  @map("place_id")
  formattedAddress String?  @map("formatted_address")
  lat       Float
  lng       Float
  arriveOn  DateTime @map("arrive_on") @db.Date
  departOn  DateTime @map("depart_on") @db.Date
  legOrder  Int      @map("leg_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripGyms TripGym[]

  @@index([tripId])
  @@map("trip_legs")
}

model TripGym {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId     String   @map("trip_id") @db.Uuid
  legId      String?  @map("leg_id") @db.Uuid
  gymId      String   @map("gym_id") @db.Uuid
  matchScore Int      @map("match_score")
  notes      String?
  savedAt    DateTime @default(now()) @map("saved_at") @db.Timestamptz

  trip Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  leg  TripLeg? @relation(fields: [legId], references: [id], onDelete: Cascade)
  gym  Gym      @relation(fields: [gymId], references: [id])

  @@index([tripId])
  @@index([legId])
  @@map("trip_gyms")
}

model TripRoute {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId  String @map("trip_id") @db.Uuid
  routeId String @map("route_id") @db.Uuid

  trip  Trip  @relation(fields: [tripId], references: [id])
  route Route @relation(fields: [routeId], references: [id])

  @@map("trip_routes")
}


model ChatThread {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  title           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastMessageAt   DateTime @default(now()) @map("last_message_at") @db.Timestamptz

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([lastMessageAt(sort: Desc)])
  @@map("chat_threads")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  role      String   // 'user' | 'assistant'
  content   String
  gymIds    Json?    @map("gym_ids")
  googlePlaceIds String[] @default([]) @map("google_place_ids")
  toolResults Json?    @map("tool_results")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([threadId, createdAt])
  @@map("chat_messages")
}

model BookingInterest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  tripId          String?  @map("trip_id") @db.Uuid
  gymId           String?  @map("gym_id") @db.Uuid
  gymPlaceId       String?  @map("gym_place_id")
  gymNameSnapshot  String?  @map("gym_name_snapshot")
  gymAddressSnapshot String? @map("gym_address_snapshot")
  email           String
  pricePence      Int      @map("price_shown_pence")
  source          String   @default("gym_card")
  status          String   @default("waitlisted")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)
  gym  Gym?  @relation(fields: [gymId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([gymId])
  @@index([createdAt(sort: Desc)])
  @@map("booking_interest")
}
